        }
        lines {
          text: "    studentCountText: \'Heritage & Conference Hub\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Teachers Camp serves as a living monument to the city\'s enduring commitment to academic heritage and intellectual growth.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuC4cz21QJbFtojGFxqc51FLPlQ2jHIWsZPhyaouo4wWiZZgu4PqRJBOvOsI62LD60VzNwK9OUJxmNS7wL5wdlgl3trSNh5tV3DRLQZHiP4-rlSPT7wNOLXx4oIt9rGISFtra8O0puoo3dFu3Z6ZTBX5cTgUtsizCOf6EBKgtIa3c77g5EjTprPKOlqlSjjhR42MRlebd4nA29SuUn0NWBzXEIkml19KXKLz5KhqKw5fwtnQTP0Pa8tNablTXlTwqdiBfM14_5XjvFjf\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    details: \'Teachers Camp was constructed in 1908 as an educational vacation resort for American Thomasite teachers who pioneered formal public classroom structures. Spreading through a pristine pine valley of several hectares, its iconic white and green timber framing captures the American-architectural heritage seamlessly and continues to host national webinars, sports camps, and civic trainings.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    keyMissions: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Maintaining the historic aesthetic values of early American-colonial architecture.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Serving as the premium National Seminar hub for the Department of Education.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Providing athletic complexes for altitude sports coaching and trials.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
