        }
        lines {
          text: "    studentCountText: \'30,000+ Students\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'The largest university north of Manila, recognized as a Center of Excellence in various disciplines. Its sprawling campus in the heart of the city is a landmark of academic rigor.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuCnbBIfYIADi4mxEOk6NHFPs2p1IRui97SrNxnuSLzcrQZDfE9PbLhZxyxI5CbmT2T6LtBI9ary8AGIaZfZCyRkz0vDJwvawTVzd-SaLnvGGYS-BRQtOtvDjxF-bYt-W8buVFIkM4-OVMaZ0YNlHpHCeY7jG0QXPY9_X-JQt-5ZaGIokGZPA0d7y3D8qMOmwk1I2i5_LnNwRhJuMzXJqM5Y3mYQ5WKk4MbPwPxayDae79oYm0ppLfmGOcfQwXGubxqA4NZbz408s8kc\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    details: \'Saint Louis University is a private Catholic university founded in 1911 by Belgian missionaries of the CICM. It has grown from a simple elementary school into an academic powerhouse featuring massive campuses across Baguio City (Main Campus, Maryheights Campus, Bakakeng Campus, and Navy Base). It excels in Medicine, Engineering, Law, and Teacher Training.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    keyMissions: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Inculcating moral Christian values and academic excellence.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Sustaining specialized research in mountain engineering and pharmaceutical science.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Active community engagement across Cordilleran remote communities.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ]"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
