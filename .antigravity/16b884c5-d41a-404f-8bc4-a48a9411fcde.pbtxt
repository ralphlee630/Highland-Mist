        lines {
          text: "    id: \'mines-view\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Mines View Park\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Experience breathtaking panoramic views of Baguio\'s gold and copper mines and the surrounding cordillera mountains. A must-visit for sunrise watchers and nature enthusiasts seeking the crisp mountain air.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'Scenic\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuDGB747f0nHuYhJ3fu4VQBIQdUmRLXWQZNvjGQT0-_qx5MK6ORne1V7FjJ993epsZerjUdIOPcZTDwAmTjj99eu8drmTewmFLBVH8MZSDDBEUXrPjLO63QQTxwnlOxNsI-mTYbvxQKVbbggAKuosGWVTKx0VzFkVizU-up7vYfN39eUEYS4cwTe2-c5ShlzjFlRNsetuDLX90z23-Jh2S7gGiiZGo82R67EDDn6fp26kuC7iHMpPFxHB2WqWqIUkxlZMrbqYe1Gezj9\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    locationDetails: \'Gibraltar Road, Baguio City, Benguet\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    historyText: \'Initially served as a primary mining observation point during the early 20th century, Mines View Park overlooks the gold and copper mines of Itogon. Over decades, it has evolved into a key lookout point and tourist bazaar offering traditional Cordilleran clothes rentals, silver-smithing stalls, and native delicacies.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    travelerTips: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Arrive before 5:45 AM to witness a cinematic mountain sunrise breaking through the clouds.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Grab a cup of warm local Strawberry Taho from vendors near the viewing deck.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Rent traditional Cordilleran attire (such as bahag and tapis) for a small cultural experience fee.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Do shop at the coordinate local handicraft stalls to directly support the native Benguet micro-entrepreneurs.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    rating: 4.6,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    reviewCount: 3420,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    hours: \'5:00 AM - 8:00 PM Daily\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    entranceFee: \'\342\202\26110.00 for Adults, \342\202\2615.00 for Children\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
