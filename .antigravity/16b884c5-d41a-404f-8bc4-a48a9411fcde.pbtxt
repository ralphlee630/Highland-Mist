        lines {
          text: "    id: \'burnham-park\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Burnham Park\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'The heart of Baguio City. Enjoy a leisurely boat ride on the man-made lake, rent a bicycle, or simply stroll through the beautifully landscaped rose and orchid gardens.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'Recreation\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuAXIWottJ9xZa15hyYbu060lsILmt27AdOMU4bnpta1rudoNgtJMTuUrrODlsNU2xN6E7pSJQGvr1UfA1H_pYL4LqgIGTQZsjKNW-jZNCjzCpnX7I9otaF1eC2O7oeOi3b9QJm4YrrOSeqFPeRr5sjTr0JTBQJxkJxjBZMFZUrBBtlfI7g5SC4l_2nu-qcxBHXmR-8NjZCMppCHeS2nu0iXIOOD1UkvbMId9pNZzyqS7Nt3-Jox_vRsaxgAERJYy2haVFnPD6pSOsar\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    locationDetails: \'Jose Abad Santos Dr, Baguio City, Benguet\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    historyText: \'Designed by the master architect Daniel Hudson Burnham in 1904, this central park is the focal urban anchor of Baguio City. Originally created as an green buffer space for the rest of his City Plan, it represents a classical Beaux-Arts park layout nested directly in high altitude.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    travelerTips: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Rent a hand-operated Swan boat on Burnham Lake for a peaceful afternoon activity.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Go to the athletic side and rent a bicycle or side-car kart (ranging from \342\202\26150-\342\202\261100/hr) to zip around the tracks.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Visit the Melvin Jones Grandstand area during weekends to watch local community performances.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Try the famous Baguio double-churned ice cream inside the Rose Garden.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    rating: 4.8,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    reviewCount: 5210,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    hours: \'Open 24 Hours\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    entranceFee: \'Free Admission (Boats & bikes are rented separately)\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
