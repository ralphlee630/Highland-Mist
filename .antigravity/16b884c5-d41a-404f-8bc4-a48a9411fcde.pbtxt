        lines {
          text: "    id: \'the-mansion\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'The Mansion\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'The official summer residence of the President of the Philippines, known for its elegant architecture and beautiful landscaped gardens framed by tall, historic pine trees.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'Heritage\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuAOyPAyl7YtudLQ-KKw8pDe4WLgeV5-WBqbLQ3cbyhV9TkdyPlsHPVrnu2yMjSH3zuvnbQq34zw4NpbWGo86HHfe9GAKRKOs3xpcaUmJOEIYBopUa48FNOUr9R3sP1B4Xt6ydCJk5yghMOO1Cs6xW3Z6IHQntA_ZBsiBkWcEh2jzaxcvuO1WsXO-Pi6Bm-V6mNCrroUKWjl_3sguxxr1xF3DK00sVqDlvzE1WWlxuUEHS81-tz-xziJj7aO3Zo4YouQ09hBz3QhJ4bM\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    locationDetails: \'C.P. Romulo Dr, Baguio City, Benguet\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    historyText: \'Constructed in 1908, The Mansion serves as the official residence and briefing venue for the Chief Executive of the Philippines during summer. Its magnificent gate is famously modeled after the Buckingham Palace gates in London, and its elegant high-contrast Spanish colonial-inspired facade has survived the challenges of World War II.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    travelerTips: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Snap elegant photos in front of the grandiose black-iron gates.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Walk across to the Wright Park Pool of Pines situated directly opposite for the ideal visual axis shot.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Remember that entering the residential palace itself is generally closed, but the outer manicured grounds and history museum are fully open to spectators.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    rating: 4.7,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    reviewCount: 1980,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    hours: \'8:00 AM - 5:00 PM Daily\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    entranceFee: \'Free Admission\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
