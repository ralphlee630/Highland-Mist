          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'Baguio enforces a strict ban on single-use plastics and polystyrene (Styrofoam) containers in all business establishments. Shoppers are required to bring eco-bags.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    bulletPoints: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Strictly bans single-use plastic grocery bags, food boxes, straws, and cutlery.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
