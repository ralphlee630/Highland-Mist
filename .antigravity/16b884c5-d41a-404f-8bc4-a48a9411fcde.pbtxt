          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    longText: \'Formulated in 1995 after the tragic 1990 Cordillera earthquake, the Panagbenga (Malayan for \"season of blooming\") was designed to celebrate the rebirth of the city. For four consecutive weeks, Session Road converts into a botanical gallery featuring floral installations, street dance performers executing Cordilleran gongs, and international crowds celebrating highland resilience.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    highlights: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Grand Floral Parade: Breathtaking towering floats made entirely out of real petals (roses, sunflowers, chrysanthemums).\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Street Dancing Extravaganza: High energy cultural dancers spinning in native Benguet woven regalia.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
