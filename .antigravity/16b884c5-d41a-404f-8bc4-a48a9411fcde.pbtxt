        }
        lines {
          text: "    studentCountText: \'3,500+ Scholars\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"The national university\'s hub for Cordillera studies, renowned for arts, sciences, and indigenous research.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuDeOuRwOR_3Wq0R6QsKa_POgV_Zn8TQdxveD1n5GL3pxVmWeUUFuVS3GOXeVrmbADQjiudvHmEZ2bxT7T0e-ovvTkwFeDlX_nN4CCjQ2DkfmrkfnJHmtMUv0yU-EmG4VZp7ovhbzhqHhJkEHTcKbwPA8IPvL0eNHbwMptdPfWMRAGDTIAvas3VZptQ2pZ6-7SjemAivcvGGCa_Ch5wj9CmS5EomcKy1_En0IBFWLta_tTqlrktKbj6bMWt6xew98WbNMMG5OkgcKfD7\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    details: \'As the pioneer regional unit of the UP system, UP Baguio stands as the leading institution for Cordillera studies. It houses the Museo Kordilyera, the first ethnographic museum dedicated strictly to mountain cultures. Known for extreme selective admissions, UP Baguio specializes in Environmental Biology, Fine Arts, Ethnomusicology, and Mathematics.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    keyMissions: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Preservation and critical documentation of Cordilleran heritage and languages.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Scholarly analysis of regional mountain geohazards and environmental stability.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Offering elite, progressive high-quality education to the northern provinces.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ]"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
