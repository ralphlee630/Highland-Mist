          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'upb\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'University of the Philippines Baguio\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    established: \'1921\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
