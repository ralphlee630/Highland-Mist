        lines {
          text: "    category: \'Health\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'Smoking and vaping are strictly prohibited in all public places, including parks, sidewalks, and public utility vehicles. Designated smoking areas are heavily regulated.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    bulletPoints: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
