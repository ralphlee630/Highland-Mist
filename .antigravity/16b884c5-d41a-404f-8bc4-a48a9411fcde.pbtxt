        lines {
          text: "    description: \'Consistently producing topnotchers, this institution is a cornerstone of professional education.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuDC0rTfgRPQP1Ob-GIvi8F57Zoho0lu3MEjusvz7A0F3axDoGOKuPFJg-hDayfLIJZebesJCYI6JiLQ8D5FeTN2qu_0VxqmHP3Bia0CwGRNUWfi5evdPy-vB2a0NKJddWFPkf4N4Hzp9EQOujBQ_namxZulLkbkzqxSNO1FwlMIAht1R1qtHkUiI-XC2FjE802xuG4K45E1PL9YJW4l9Dx9WdhfVmhy2Gj_6fc71eBrAX0VgeDq8szts1Qc4BmDHTmR4Tr8Olvo-wkD\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    details: \'Formerly Baguio Colleges Foundation (BCF), UC is famous for setting national records in Bar examinations and Engineering licensures. Its iconic green-slatted campus adapts excellently to the hillside terrain. It is widely acclaimed for its advanced Information Technology programs and digital governance studies.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    keyMissions: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
