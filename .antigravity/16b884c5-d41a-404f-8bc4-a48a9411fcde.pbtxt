        lines {
          text: "    id: \'strawberry-farm\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Strawberry Farm\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Located in nearby La Trinidad, pick your own fresh strawberries straight from the fields. A delightful agriculture-tourism experience that connects visitors with the region\'s rich, fertile soils.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'Agri-Tourism\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuAjeXHRyjzm4viRnSwwceI7IneJWoNztgHY_z9ZHBW6VdAdbn82esXkkdZ8zUhW--Wqkl_tN2t20ERJMW8HchAHefHnCus9dhHhwl20F2Jo6pBllN3N_cjqgXi90uVQinYSBq1hUuCMJn9gcrd4Lq7o5e_BIuW8P_N2d9AGLJ0pk3GY8jk9BGcjN_OvfvU9Wwou8T2McpUyRZk38QLpVukLvdR0DKnbTkcFfDaw3oWL-62pizrgAlVlpWmQ2C_SMvATIdwFu-_8AR9Z\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    locationDetails: \'Km. 5, La Trinidad, Benguet (15 mins from Baguio)\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    historyText: \'Operated by local cooperative Benguet farmers, this swamp land in La Trinidad was transformed into a flourishing strawberry oasis. It stands as one of the very few places in the tropical Philippines that can cultivate high-quality strawberries.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    travelerTips: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'The prime harvesting season runs from November to April when strawberries are sweet and bright red.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Always dress in comfortable boots as paths can be muddy after morning fog.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Purchase home-cooked strawberry jam, strawberry wine, and unique strawberry-flavored crafts right at the farm gate.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Try the strawberry-infused taho or fresh strawberry ice cream from the local cart sellers.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    rating: 4.5,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    reviewCount: 4120,"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    hours: \'7:00 AM - 6:00 PM Daily\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    entranceFee: \'Free Entrance (Strawberry picking is charged per kilo, approx \342\202\261400-\342\202\261500/kg)\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  },"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "  {"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    id: \'camp-john-hay\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    name: \'Camp John Hay\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'Wander through acres of preserved pine forests. A premier destination for historic eco-trails, high-altitude golf courses, premium dining, and fresh mountain breezes.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'Nature\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuA_eTtYiGsbRDGU2qaZaRcHpbJZsbchy7SMsaGan9GTjfkpA5S1VitrZMIkmOG1ZewvAqazy_TqwyA2fi1twaPI2_XLoTIKi3u_b6M1r8mMGhsA7daHf6g5IG8N4ikzK9yLylkeLqQ1baWqu15BbHq62VmJr8ZAuQO35eEfrMgnel9sNa5cfPxFgAQwbxf1bxGwNHlx6RduephDzDt3eOiFpE-mSykpQSv4Q4sCXJOXecEU5N0XQ4duowJgrkwmHGFck4eyaJ82OPXj\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    locationDetails: \'Loakan Road, Baguio City, Benguet\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    historyText: \'Established in October 1903 as a rest and recreation camp for the United States Armed Forces, Camp John Hay was named after US Secretary of State John Milton Hay. It was handed over to the Philippine government in 1991 and converted into a pristine public forest reserve and high-end tourism estate.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    travelerTips: ["
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Walk alongside the Yellow Trail, a beautiful 4km trail wrapping under tall pine tree canopies.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Visit the Bell House for deep insights into American historical military lifestyle.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Relax at the Bell Amphitheater with its multi-tiered garden seating.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "      \'Taste premium local hot chocolate de batirol nested inside the garden sanctuary.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    ],"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
