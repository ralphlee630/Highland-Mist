          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \"Celebrated every February, the Flower Festival is a stunning tribute to the city\'s resilience and its abundance of flora. It is a sensory feast of color, music, and community spirit.\","
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    category: \'Festival\',"
