        }
        lines {
          text: "    category: \'Roots\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    image: \'https://lh3.googleusercontent.com/aida-public/AB6AXuAz-L2oHgXOQwBUJUnsDp1fKlWE6uZX9Tna7jXXtlgZOPw4aZ5OOcjcHtnvI4eR0A3KD6oOknQc5NWfxAjOYwghBy7xfmL24xvfMjpwmMZOl4KMZ1AKQvDLBPKErLjBCEetpOc3IJVQaqtL0qCIeGn2aI5oM4QaY7wHC3Z9Ldr-NXi7ywPP_na2JaqlRKvjVPatCsLtMAWGOQ5IjjJFyS-ewUjXMRBXWDROYLdpMpN-XkhRcb0eZ4rZZ9L1Wt0aJ080qSp5SHUtD4xS\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    longText: \'Traditional weaving is a highly sacred local science. Cordilleran patterns reflect tribal hierarchy, ancestry, and alignment with nature. Modern weavers in Saint Louis Filigree centers and Easter Weaving Room carry on this laborious art by relying strictly on manual timber backstrap looms, turning organic yarns into high-fashion clothing, blankets, and bags.\'"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
