        lines {
          text: "    category: \'Civic\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "    description: \'Vehicle restriction applies from 6:00 AM to 7:00 PM within the Central Business District (CBD) based on the ending digit of your license plate. Check local advisories for zone boundaries.\',"
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
